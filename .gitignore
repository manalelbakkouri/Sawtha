# ==========================================================
# Sawtha MVP - Git Ignore
# FastAPI backend + React/Vite frontend + AI demo files
# ==========================================================


# ==========================================================
# System files
# ==========================================================
.DS_Store
Thumbs.db
desktop.ini


# ==========================================================
# Environment variables / secrets
# ==========================================================
.env
.env.local
.env.*.local
*.env

# Keep example env files
!.env.example
!backend/.env.example
!frontend/.env.example


# ==========================================================
# Python / FastAPI backend
# ==========================================================
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

.Python
.python-version

venv/
.venv/
env/
ENV/
backend/venv/
backend/.venv/

pip-wheel-metadata/
*.egg-info/
.eggs/
dist/
build/

.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

*.log
logs/
backend/logs/


# ==========================================================
# Node / React / Vite frontend
# ==========================================================
node_modules/
frontend/node_modules/

frontend/dist/
frontend/build/
frontend/.vite/
.vite/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ==========================================================
# Lock files
# ==========================================================
# For MVP stability, we keep package-lock.json committed.
# Do NOT ignore package-lock.json unless you want fresh installs every time.
# package-lock.json
# yarn.lock
# pnpm-lock.yaml


# ==========================================================
# Sawtha backend generated runtime data
# These files are generated/updated during demo runs.
# Keep seed files like patients.json and care_plans.json.
# ==========================================================
backend/app/data/checkins_history.json
backend/app/data/alerts.json
backend/app/data/generated_reports.json

# Optional local runtime snapshots
backend/app/data/runtime/
backend/app/data/tmp/


# ==========================================================
# Sawtha seed/static data to KEEP in Git
# Do not ignore these if they are part of the demo dataset:
# backend/app/data/patients.json
# backend/app/data/care_plans.json
# backend/app/data/trusted_people.json
# backend/app/data/medical_staff.json
# backend/app/data/health_centers_mock.json
# backend/app/data/mobility_network.json
# backend/app/data/medical_rules.json
# backend/app/data/checkin_scenarios.json
# backend/app/data/call_dialogues.json


# ==========================================================
# Audio / speech-to-text demo files
# ==========================================================
*.wav
*.mp3
*.m4a
*.webm
*.ogg

backend/uploads/
backend/app/uploads/
frontend/public/recordings/


# ==========================================================
# AI model files / local model cache
# ==========================================================
models/
backend/models/
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.onnx

.cache/
.cache/huggingface/
backend/.cache/


# ==========================================================
# Reports / exports generated by Sawtha
# ==========================================================
exports/
reports/
backend/exports/
backend/reports/

*.pdf
*.xlsx
*.csv


# ==========================================================
# Local databases
# ==========================================================
*.sqlite
*.sqlite3
*.db
backend/*.sqlite
backend/*.sqlite3
backend/*.db


# ==========================================================
# IDE / editors
# ==========================================================
.vscode/
.idea/
*.swp
*.swo


# ==========================================================
# Temporary files
# ==========================================================
tmp/
temp/
*.tmp